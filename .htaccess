# mARI Platform - Professional Hybrid Deployment
RewriteEngine On
RewriteBase /

# 1. Start Node server from our Git root folder
<IfModule mod_passenger.c>
  PassengerEnabled on
  # PATH MUST BE ABSOLUTE TO WORK on Hostinger Shared
  PassengerAppRoot /home/u723774100/domains/orangered-clam-470152.hostingersite.com/public_html
  PassengerStartupFile index.js
  PassengerAppType node
</IfModule>

# 2. Force index.js to be the primary entry point
DirectoryIndex index.js index.html
Options +FollowSymLinks -Indexes

# 3. Serve static files from the pre-built /dist folder
RewriteCond %{DOCUMENT_ROOT}/dist/%{REQUEST_URI} -f
RewriteRule ^(.*)$ /dist/$1 [L]

# 4. Proxy all API and missing routes to the Node app
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.js [L]
