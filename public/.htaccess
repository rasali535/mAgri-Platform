<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # 1. Route USSD and Health checks directly to Node
  RewriteRule ^(ussd|ussd-health|health|status)$ index.js [L]
  RewriteRule ^api/.*$ index.js [L]
  
  # 2. Serve static files if they exist
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^(.*)$ - [L]
  
  # 3. Fallback everything else to Node (SPA routing)
  RewriteRule ^(.*)$ index.js [L]
</IfModule>

# Phusion Passenger Setup
<IfModule mod_passenger.c>
  PassengerEnabled on
  PassengerAppRoot /
  PassengerStartupFile index.js
  PassengerAppType node
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Enable GZIP compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>
